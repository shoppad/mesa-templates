{
    "key": "recharge/charge/tag_shopify_customer_when_payment_fails",
    "name": "Tag Shopify Customer When Recharge Subscription Payment Fails",
    "version": "1.0.0",
    "enabled": false,
    "setup": true,
    "config": {
        "inputs": [
            {
                "schema": 2,
                "trigger_type": "input",
                "type": "recharge",
                "entity": "charge",
                "action": "charge\/failed",
                "name": "Recharge Charge Failed",
                "key": "recharge_charge",
                "operation_id": "charge_failed",
                "metadata": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 0
            }
        ],
        "outputs": [
            {
                "schema": 3.1,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "customer_search",
                "action": "list",
                "name": "Find Shopify Customer by Email",
                "key": "shopify_customer_search",
                "operation_id": "get_customers_search",
                "metadata": {
                    "api_endpoint": "get admin\/customers\/search.json",
                    "parameters": "query=email:{{recharge_customer.email}}"
                },
                "selected_fields": ["parameters"],
                "on_error": "default",
                "weight": 0
            },
            {
                "schema": 3.1,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "customer",
                "action": "tag_add",
                "name": "Tag Shopify Customer",
                "key": "shopify_customer",
                "operation_id": "post_mesa_customers_customer_id_tag",
                "metadata": {
                    "api_endpoint": "post mesa\/customers\/{{customer_id}}\/tag.json",
                    "customer_id": "{{shopify_customer_search.0.id}}",
                    "body": {
                        "tag": "recharge_payment_failed"
                    }
                },
                "selected_fields": ["customer_id", "body.tag"],
                "on_error": "default",
                "weight": 1
            }
        ]
    }
}
