{
    "key": "recharge/charge/tag_shopify_customer_when_payment_fails",
    "name": "Tag Shopify Customer When Recharge Subscription Payment Fails",
    "version": "1.0.0",
    "enabled": false,
    "setup": true,
    "config": {
        "inputs": [
            {
                "schema": 2,
                "trigger_type": "input",
                "type": "recharge",
                "entity": "charge",
                "action": "charge\/failed",
                "name": "Recharge Charge Failed",
                "key": "recharge_charge",
                "operation_id": "charge_failed",
                "metadata": [],
                "local_fields": [],
                "selected_fields": ["topic"],
                "on_error": "default",
                "weight": 0
            }
        ],
        "outputs": [
            {
                "schema": 4,
                "trigger_type": "output",
                "type": "recharge",
                "entity": "customer",
                "action": "retrieve",
                "name": "Retrieve Customer",
                "key": "recharge",
                "operation_id": "get-customers-customer_id",
                "metadata": {
                    "api_endpoint": "get \/customers\/{customer_id}",
                    "path": {
                        "customer_id": "{{recharge_charge.customer.id}}"
                    }
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 0
            },
            {
                "schema": 3.1,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "customer",
                "action": "retrieve",
                "name": "Retrieve Customer",
                "key": "shopify",
                "operation_id": "get_customers_customer_id",
                "metadata": {
                    "api_endpoint": "get admin\/customers\/{{customer_id}}.json",
                    "customer_id": "{{recharge.external_customer_id.ecommerce}}"
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 1
            },
            {
                "schema": 3.1,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "customer",
                "action": "tag_add",
                "name": "Tag Shopify Customer",
                "key": "shopify_customer",
                "operation_id": "post_mesa_customers_customer_id_tag",
                "metadata": {
                    "api_endpoint": "post mesa\/customers\/{{customer_id}}\/tag.json",
                    "customer_id": "{{shopify.id}}",
                    "body": {
                        "tag": "recharge_payment_failed"
                    }
                },
                "local_fields": [],
                "selected_fields": ["customer_id", "body.tag"],
                "on_error": "default",
                "weight": 2
            }
        ]
    }
}
