{
    "key": "shopify/customer/tag_customers_with_edu_email",
    "name": "Add an educational discount tag to a customer",
    "version": "1.0.0",
    "enabled": false,
    "setup": true,
    "config": {
        "inputs": [
            {
                "schema": 2,
                "trigger_type": "input",
                "type": "shopify",
                "entity": "order",
                "action": "created",
                "name": "Order Created",
                "version": "v2",
                "key": "shopify_order",
                "operation_id": "orders_create",
                "metadata": [],
                "local_fields": [],
                "on_error": "default",
                "weight": 0
            }
        ],
        "outputs": [
            {
                "schema": 2,
                "trigger_type": "output",
                "type": "filter",
                "name": "Filter",
                "key": "filter",
                "metadata": {
                    "a": ".edu",
                    "comparison": "in",
                    "b": "{{shopify_order.email}}"
                },
                "local_fields": [],
                "on_error": "default",
                "weight": 0
            },
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "customer",
                "action": "add",
                "name": "Customer Add Tag",
                "version": "v2",
                "key": "shopify_customer",
                "operation_id": "customerTagsAdd",
                "metadata": {
                    "api_endpoint": "post /graphql/customerTags/add",
                    "body": {
                        "id": "{{shopify_order.customer.id}}",
                        "tags": "{{ template | label: 'What tag would you like to add to the customer?',  default: 'education', tokens: false }}"
                    }
                },
                "local_fields": [],
                "selected_fields": [
                    "id",
                    "tags",
                    "body",
                    "body.id",
                    "body.tags"
                ],
                "on_error": "default",
                "weight": 1
            }
        ],
        "storage": []
    }
}