{
    "key": "shopify/product/tag_products_on_sale_kj",
    "name": "Tag Shopify Products as \"On Sale\" Based on Compare-at Price",
    "version": "1.0.0",
    "enabled": false,
    "setup": true,
    "config": {
        "inputs": [
            {
                "schema": 3,
                "trigger_type": "input",
                "type": "shopify",
                "entity": "product",
                "action": "updated",
                "name": "Product Updated",
                "key": "shopify",
                "operation_id": "products_update",
                "metadata": {
                    "frequency": "every",
                    "includeFields": []
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 0
            }
        ],
        "outputs": [
            {
                "schema": 3.1,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "product_variant",
                "action": "list",
                "name": "Get List of Product Variants",
                "key": "shopify_1",
                "operation_id": "get_products_product_id_variants",
                "metadata": {
                    "api_endpoint": "get admin\/products\/{{product_id}}\/variants.json",
                    "product_id": "{{shopify.id}}"
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 0
            },
            {
                "schema": 5.1,
                "trigger_type": "output",
                "type": "loop",
                "entity": "loop",
                "name": "Loop Over Variants and Filter",
                "version": "v3",
                "key": "loop",
                "operation_id": "loop_loop",
                "metadata": {
                    "filter": {
                        "a": "{{shopify_1[].compare_at_price}}",
                        "comparison": "is not empty",
                        "additional": [
                            {
                                "operator": "and",
                                "a": "{{shopify_1[].price}}",
                                "comparison": "less than",
                                "b": "{{shopify_1[].compare_at_price}}"
                            }
                        ]
                    },
                    "key": "{{shopify_1}}"
                },
                "local_fields": [],
                "selected_fields": [
                    "filter.additional[].operator",
                    "filter.additional[].a",
                    "filter.additional[].comparison",
                    "filter.additional[].b"
                ],
                "on_error": "default",
                "weight": 1
            },
            {
                "schema": 3.1,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "product",
                "action": "tag_add",
                "name": "Product Add Tag",
                "key": "shopify_2",
                "operation_id": "post_mesa_products_product_id_tag",
                "metadata": {
                    "api_endpoint": "post mesa\/products\/{{product_id}}\/tag.json",
                    "product_id": "{{shopify.id}}",
                    "trigger_parent_key": "loop",
                    "body": {
                        "tag": "On Sale"
                    }
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 2
            },
            {
                "schema": 5.1,
                "trigger_type": "output",
                "type": "loop",
                "entity": "end",
                "name": "Loop End",
                "version": "v3",
                "key": "loop_1",
                "operation_id": "loop_end",
                "metadata": {
                    "trigger_manager_key": "loop",
                    "trigger_parent_key": "loop"
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 3
            }
        ]
    }
}
