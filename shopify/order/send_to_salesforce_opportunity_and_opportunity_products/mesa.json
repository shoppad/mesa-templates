{
    "key": "shopify/order/send_to_salesforce_opportunity_and_opportunity_products",
    "name": "Sync Shopify Orders to Salesforce Opportunities with Opportunity Products",
    "version": "1.0.0",
    "enabled": false,
    "setup": false,
    "config": {
        "inputs": [
            {
                "schema": 3,
                "trigger_type": "input",
                "type": "shopify",
                "entity": "order",
                "action": "created",
                "name": "Order Created",
                "key": "shopify_order_created",
                "operation_id": "orders_create",
                "metadata": {
                    "frequency": "every",
                    "includeFields": []
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 0
            }
        ],
        "outputs": [
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "salesforce",
                "entity": "account",
                "action": "query",
                "name": "Query Single Account",
                "key": "salesforce_query_single_account",
                "operation_id": "account_query",
                "metadata": {
                    "entity_name": "Account",
                    "method": "QUERY",
                    "salesforce_query": "SELECT Id,Name FROM Account WHERE Shopify_Customer_ID__c='{{shopify_order_created.customer.id}}'"
                },
                "local_fields": [],
                "selected_fields": [
                    "salesforce_query"
                ],
                "on_error": "default",
                "weight": 0
            },
            {
                "schema": 2,
                "trigger_type": "output",
                "type": "custom",
                "name": "Custom Code: Get Order Variants IDs",
                "key": "custom_get_order_variant_ids",
                "operation_id": "custom",
                "metadata": {
                    "script": "custom_get_order_variant_ids.js"
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 1
            },
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "salesforce",
                "entity": "product",
                "action": "query_multiple",
                "name": "Query Multiple Products",
                "key": "salesforce_query_multiple_product",
                "operation_id": "product_query_multiple",
                "metadata": {
                    "entity_name": "Product2",
                    "method": "QUERY_MULTIPLE",
                    "salesforce_query": "SELECT ID,Shopify_Variant_Id__c FROM Product2 WHERE Shopify_Variant_Id__c IN ({{custom_get_order_variant_ids.variant_ids_csv}})"
                },
                "local_fields": [],
                "selected_fields": [
                    "salesforce_query"
                ],
                "on_error": "default",
                "weight": 2
            },
            {
                "schema": 4,
                "trigger_type": "output",
                "type": "transform",
                "entity": "mapping",
                "name": "Mapping to Salesforce Create Opportunity",
                "key": "mapping_to_salesforce_create_opportunity",
                "operation_id": "mapping",
                "metadata": {
                    "mapping": [
                        {
                            "destination": "AccountId",
                            "source": "{{salesforce_query_single_account.Id}}"
                        },
                        {
                            "destination": "Amount",
                            "source": "{{shopify_order_created.total_price}}"
                        },
                        {
                            "destination": "CloseDate",
                            "source": "{{shopify_order_created.created_at}}"
                        },
                        {
                            "destination": "Description",
                            "source": "{{shopify_order_created.note}}"
                        },
                        {
                            "destination": "StageName",
                            "source": "Closed Won"
                        },
                        {
                            "destination": "Pricebook2Id"
                        },
                        {
                            "destination": "Name",
                            "source": "{{salesforce_query_single_account.Name}} - {{shopify_order_created.name}}"
                        }
                    ]
                },
                "local_fields": [
                    {
                        "key": "mapping",
                        "type": "mapping",
                        "tokens": "brackets",
                        "location": "required"
                    }
                ],
                "selected_fields": [],
                "on_error": "default",
                "weight": 3
            },
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "salesforce",
                "entity": "opportunity",
                "action": "create",
                "name": "Create Opportunity",
                "key": "salesforce_create_opportunity",
                "operation_id": "opportunity_create",
                "metadata": {
                    "entity_name": "Opportunity",
                    "method": "POST"
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 4
            },
            {
                "schema": 2,
                "trigger_type": "output",
                "type": "custom",
                "name": "Custom Code: Append Salesforce Product ID to line items",
                "key": "custom_append_sf_product_ids_to_line_items",
                "operation_id": "custom",
                "metadata": {
                    "script": "custom_append_sf_product_ids_to_line_items.js"
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 5
            },
            {
                "schema": 5.1,
                "trigger_type": "output",
                "type": "loop",
                "entity": "loop",
                "name": "Loop",
                "version": "v3",
                "key": "loop",
                "operation_id": "loop_loop",
                "metadata": {
                    "key": "{{custom_append_sf_product_ids_to_line_items.line_items[]}}",
                    "return": false
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 6
            },
            {
                "schema": 4,
                "trigger_type": "output",
                "type": "transform",
                "entity": "mapping",
                "name": "Mapping to Salesforce: Create Opportunity Product",
                "key": "salesforce_create_opportunity_product_transform",
                "operation_id": "mapping",
                "metadata": {
                    "trigger_parent_key": "loop",
                    "mapping": [
                        {
                            "destination": "OpportunityId",
                            "source": "{{salesforce_create_opportunity.id}}"
                        },
                        {
                            "destination": "UnitPrice",
                            "source": "{{loop.price}}"
                        },
                        {
                            "destination": "Quantity",
                            "source": "{{loop.quantity}}"
                        },
                        {
                            "destination": "Product2Id",
                            "source": "{{loop.salesforce_product_id}}"
                        }
                    ],
                    "script": "salesforce_create_opportunity_product_transform.js"
                },
                "local_fields": [
                    {
                        "key": "mapping",
                        "type": "mapping",
                        "tokens": "brackets",
                        "location": "required"
                    }
                ],
                "selected_fields": [],
                "on_error": "default",
                "weight": 7
            },
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "salesforce",
                "entity": "opportunity_product",
                "action": "create",
                "name": "Create Opportunity Product",
                "key": "salesforce_create_opportunity_product",
                "operation_id": "opportunity_product_create",
                "metadata": {
                    "entity_name": "OpportunityLineItem",
                    "method": "POST",
                    "trigger_parent_key": "loop"
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 8
            },
            {
                "schema": 5.1,
                "trigger_type": "output",
                "type": "loop",
                "entity": "end",
                "name": "Loop End",
                "version": "v3",
                "key": "loop_1",
                "operation_id": "loop_end",
                "metadata": {
                    "trigger_manager_key": "loop",
                    "trigger_parent_key": "loop",
                    "return": false
                },
                "local_fields": [],
                "selected_fields": [],
                "on_error": "default",
                "weight": 9
            }
        ]
    }
}