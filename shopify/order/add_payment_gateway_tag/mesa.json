{
    "key": "shopify/order/add_payment_gateway_tag",
    "name": "Add a payment gateway tag to a Shopify order",
    "version": "1.0.0",
    "description": "Add payment gateway tag to Shopify order when order is created.",
    "video": "",
    "readme": "",
    "tags": [],
    "source": "shopify",
    "destination": "shopify",
    "enabled": false,
    "logging": false,
    "debug": false,
    "setup": true,
    "config": {
        "inputs": [
            {
                "schema": 2,
                "trigger_type": "input",
                "type": "shopify",
                "entity": "order",
                "action": "created",
                "name": "Order Created",
                "version": "v2",
                "key": "shopify_order",
                "operation_id": "orders_create",
                "metadata": [],
                "on_error": "default",
                "weight": 0
            }
        ],
        "outputs": [
            {
                "schema": 2,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "order",
                "action": "retrieve",
                "name": "Retrieve Order",
                "version": "v2",
                "key": "shopify_order_2",
                "operation_id": "order",
                "metadata": {
                    "api_endpoint": "get /graphql/order/retrieve",
                    "body": {
                        "id": "{{shopify_order.id}}"
                    }
                },
                "local_fields": [],
                "selected_fields": [
                    "id",
                    "body",
                    "body.id"
                ],
                "on_error": "default",
                "weight": 0
            },
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "order",
                "action": "update",
                "name": "Update Order",
                "version": "v2",
                "key": "shopify_order_1",
                "operation_id": "orderUpdate",
                "metadata": {
                    "api_endpoint": "post /graphql/order/update",
                    "body": {
                        "id": "{{shopify_order.id}}",
                        "tags": "{{shopify_order_2.tags | join: \", \"}}, {{shopify_order_2.paymentGatewayNames | join: \", \"}}"
                    }
                },
                "local_fields": [],
                "selected_fields": [
                    "id",
                    "tags",
                    "body",
                    "body.id",
                    "body.tags"
                ],
                "on_error": "default",
                "weight": 1
            }
        ],
        "storage": []
    }
