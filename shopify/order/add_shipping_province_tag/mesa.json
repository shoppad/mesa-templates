{
    "key": "shopify/order/add_shipping_province_tag",
    "name": "Tag a Shopify order with the shipping province or state",
    "version": "1.0.0",
    "enabled": false,
    "setup": true,
    "config": {
        "inputs": [
            {
                "schema": 2,
                "trigger_type": "input",
                "type": "shopify",
                "entity": "order",
                "action": "created",
                "name": "Order Created",
                "version": "v2",
                "key": "shopify_order",
                "operation_id": "orders_create",
                "metadata": [],
                "local_fields": [],
                "on_error": "default",
                "weight": 0
            }
        ],
        "outputs": [
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "order",
                "action": "add",
                "name": "Order Add Tag",
                "version": "v2",
                "key": "shopify",
                "operation_id": "orderTagsAdd",
                "metadata": {
                    "api_endpoint": "post /graphql/orderTags/add",
                    "body": {
                        "id": "{{shopify_order.id}}",
                        "tags": "{{shopify_order.shipping_address.province_code}}"
                    }
                },
                "local_fields": [],
                "selected_fields": [
                    "id",
                    "tags",
                    "body",
                    "body.id",
                    "body.tags"
                ],
                "on_error": "default",
                "weight": 0
            }
        ]
    }
}