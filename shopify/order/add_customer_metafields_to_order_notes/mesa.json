{
    "key": "shopify/order/add_customer_metafields_to_order_notes",
    "name": "Add customer metafields to Shopify order notes",
    "version": "1.0.0",
    "enabled": false,
    "setup": true,
    "config": {
        "inputs": [
            {
                "schema": 3,
                "trigger_type": "input",
                "type": "shopify",
                "entity": "order",
                "action": "created",
                "name": "Order Created",
                "version": "v2",
                "key": "shopify",
                "operation_id": "orders_create",
                "metadata": [],
                "on_error": "default",
                "weight": 0
            }
        ],
        "outputs": [
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "metafield",
                "action": "list",
                "name": "Get List of Metafields",
                "version": "v2",
                "key": "shopify_1",
                "operation_id": "metafieldList",
                "metadata": {
                    "api_endpoint": "post /graphql/metafield/list",
                    "body": {
                        "ownerId": "{{shopify.customer.id}}",
                        "ownerType": "Customer"
                    }
                },
                "local_fields": [],
                "selected_fields": [
                    "ownerId",
                    "ownerType",
                    "body",
                    "body.ownerId",
                    "body.ownerType"
                ],
                "on_error": "default",
                "weight": 0
            },
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "order",
                "action": "create",
                "name": "Update Order Notes",
                "version": "v2",
                "key": "shopify_2",
                "operation_id": "put_mesa_orders_order_id_note",
                "metadata": {
                    "api_endpoint": "post /graphql/order/noteUpdate",
                    "body": {
                        "id": "{{shopify.id}}",
                        "note": "{% for metafield in shopify_1.metafields %} - {{metafield.key | replace: \"_\", \" \"| capitalize}}: {{metafield.value}}\n{% endfor %}",
                        "append": true
                    }
                },
                "local_fields": [],
                "selected_fields": [
                    "id",
                    "note",
                    "append",
                    "body",
                    "body.id",
                    "body.note",
                    "body.append"
                ],
                "on_error": "default",
                "weight": 1
            }
        ]
    }
}