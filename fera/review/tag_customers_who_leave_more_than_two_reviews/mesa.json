{
    "key": "fera/review/tag_customers_who_leave_more_than_two_reviews",
    "name": "Tag customers when they leave more than 2 reviews",
    "version": "1.0.0",
    "enabled": false,
    "setup": true,
    "config": {
        "inputs": [
            {
                "schema": 4,
                "trigger_type": "input",
                "type": "fera",
                "entity": "review_create",
                "action": "created",
                "name": "Review Created",
                "key": "fera",
                "operation_id": "review_create",
                "metadata": [],
                "local_fields": [],
                "on_error": "default",
                "weight": 0
            }
        ],
        "outputs": [
            {
                "schema": 4,
                "trigger_type": "output",
                "type": "fera",
                "entity": "customer",
                "action": "retrieve",
                "name": "Retrieve Customer",
                "key": "fera_2",
                "operation_id": "retrieve-customer",
                "metadata": {
                    "api_endpoint": "get /customers/{id}",
                    "path": {
                        "id": "{{fera.customer_id}}"
                    }
                },
                "local_fields": [],
                "on_error": "default",
                "weight": 0
            },
            {
                "schema": 4,
                "trigger_type": "output",
                "type": "filter",
                "name": "Filter",
                "key": "filter",
                "metadata": {
                    "comparison": "greater than",
                    "b": "{{ template | label: 'What is the minimum number of reviews that the customer must leave?', default: 2, type: 'number', tokens: false }}",
                    "a": "{{fera_2.counts.reviews}}"
                },
                "local_fields": [],
                "on_error": "default",
                "weight": 1
            },
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "customer",
                "action": "retrieve",
                "name": "Retrieve Customer",
                "version": "v2",
                "key": "shopify",
                "operation_id": "customer",
                "metadata": {
                    "api_endpoint": "get /graphql/customer/retrieve",
                    "body": {
                        "id": "{{fera.external_customer_id}}"
                    }
                },
                "local_fields": [],
                "selected_fields": [
                    "id",
                    "body",
                    "body.id"
                ],
                "on_error": "default",
                "weight": 2
            },
            {
                "schema": 3,
                "trigger_type": "output",
                "type": "shopify",
                "entity": "customer",
                "action": "add",
                "name": "Customer Add Tag",
                "version": "v2",
                "key": "shopify_1",
                "operation_id": "customerTagsAdd",
                "metadata": {
                    "api_endpoint": "post /graphql/customerTags/add",
                    "body": {
                        "id": "{{shopify.id}}",
                        "tags": "{{ template | label: 'What would you like to tag your customers?', default: 'engaged', tokens: false }}"
                    }
                },
                "local_fields": [],
                "selected_fields": [
                    "id",
                    "tags",
                    "body",
                    "body.id",
                    "body.tags"
                ],
                "on_error": "default",
                "weight": 3
            }
        ]
    }
}